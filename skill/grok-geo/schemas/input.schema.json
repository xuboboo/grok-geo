{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://geo-audit.local/schemas/input.schema.json",
  "title": "GEO Brand Audit Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["brand_name", "website", "industry", "target_customer"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "mode": {
      "type": "string",
      "enum": ["quick", "standard", "offline_import"],
      "default": "standard"
    },
    "brand_name": { "type": "string", "minLength": 1, "maxLength": 200 },
    "brand_aliases": {
      "type": "array",
      "maxItems": 20,
      "items": { "type": "string", "minLength": 1, "maxLength": 200 }
    },
    "website": {
      "type": "string",
      "format": "uri",
      "pattern": "^https?://"
    },
    "industry": { "type": "string", "minLength": 1, "maxLength": 200 },
    "products": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 200 },
          "aliases": {
            "type": "array",
            "items": { "type": "string", "minLength": 1, "maxLength": 200 }
          },
          "summary": { "type": "string", "maxLength": 2000 }
        }
      }
    },
    "target_customer": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "target_region": {
      "type": "array",
      "maxItems": 10,
      "items": { "type": "string", "minLength": 1, "maxLength": 100 }
    },
    "language": { "type": "string", "default": "zh-CN" },
    "competitors": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 200 },
          "website": { "type": ["string", "null"], "format": "uri" }
        }
      }
    },
    "business_goals": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 100 }
    },
    "known_facts": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "required": ["statement", "source_url"],
        "properties": {
          "statement": { "type": "string" },
          "source_url": { "type": "string", "format": "uri" },
          "valid_from": { "type": ["string", "null"], "format": "date" },
          "valid_to": { "type": ["string", "null"], "format": "date" }
        }
      }
    },
    "forbidden_claims": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "question_count": { "type": "integer", "minimum": 1, "maximum": 40 },
        "query_variants": { "type": "integer", "minimum": 1, "maximum": 2 },
        "max_opportunities": { "type": "integer", "minimum": 1, "maximum": 10 },
        "max_content_briefs": { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    }
  }
}